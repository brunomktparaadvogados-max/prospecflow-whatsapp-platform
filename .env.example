# ══════════════════════════════════════════════════════════
# ProspecFlow WhatsApp Platform — Variáveis de Ambiente
# ══════════════════════════════════════════════════════════

PORT=3000
NODE_ENV=production

# Banco de dados PostgreSQL (Supabase, Neon, etc)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# JWT Secret — MUDE EM PRODUÇÃO!
JWT_SECRET=prospecflow-secret-change-in-production

# URL pública da API (para webhooks)
API_URL=https://sua-api.koyeb.app

# Token de verificação do webhook da Meta
# Use este mesmo valor ao configurar o webhook no Meta Developers
META_WEBHOOK_VERIFY_TOKEN=prospecflow_webhook_2024
